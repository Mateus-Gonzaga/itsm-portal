# Modelo de .env para PRODUÇÃO. Copie para .env e preencha:
#   cp .env.prod.example .env  &&  nano .env
# NUNCA versione o .env real (ele tem senhas).

APP_NAME="FOURLINE Connect"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://SEU_IP:8088

# Banco do portal (PostgreSQL no container db) — troque a senha.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=itsm
DB_USERNAME=itsm
DB_PASSWORD=TROQUE_ESTA_SENHA

# Sessão/cache/fila no banco (sem precisar de Redis).
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# GLPI de produção (conta de serviço RESTRITA, não super-admin).
GLPI_DRIVER=api
GLPI_API_URL=http://IP_DA_VM_GLPI/apirest.php
GLPI_API_USER=conta_servico
GLPI_API_PASSWORD=

# Zabbix de produção (usuário só-leitura).
ZABBIX_DRIVER=api
ZABBIX_API_URL=http://192.168.101.26/api_jsonrpc.php
ZABBIX_USER=
ZABBIX_PASSWORD=
